{
    // VSCode tasks used by launch.json.
    // The "frontend: npm run dev" task is a background task that launches
    // Vite and returns control to the debugger once Vite reports "ready".
    // VSCode detects that signal via the `problemMatcher.background.endsPattern`
    // regex below — adjust it if Vite ever changes its startup banner.
    "version": "2.0.0",
    "tasks": [
        {
            "label": "frontend: npm run dev",
            "type": "shell",
            "command": "npm run dev",
            "options": {
                "cwd": "${workspaceFolder}/frontend"
            },
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "ai-pm-frontend",
                "clear": true
            },
            "problemMatcher": {
                "owner": "vite",
                "pattern": {
                    "regexp": "^$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "VITE v",
                    "endsPattern": "ready in \\d+"
                }
            }
        },
        {
            "label": "frontend: stop dev server",
            "type": "shell",
            "command": "echo 'Stopping Vite (kill the dedicated terminal panel if it is still running).'",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        },
        {
            "label": "backend: pytest",
            "type": "shell",
            "command": "${workspaceFolder}/backend/venv/Scripts/python.exe",
            "args": [
                "-m",
                "pytest",
                "-v"
            ],
            "options": {
                "cwd": "${workspaceFolder}/backend"
            },
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "backend: alembic upgrade head",
            "type": "shell",
            "command": "${workspaceFolder}/backend/venv/Scripts/python.exe",
            "args": [
                "-m",
                "alembic",
                "upgrade",
                "head"
            ],
            "options": {
                "cwd": "${workspaceFolder}/backend"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "frontend: npm install",
            "type": "shell",
            "command": "npm install",
            "options": {
                "cwd": "${workspaceFolder}/frontend"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "frontend: npm run build",
            "type": "shell",
            "command": "npm run build",
            "options": {
                "cwd": "${workspaceFolder}/frontend"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}
