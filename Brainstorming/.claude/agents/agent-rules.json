    "workflow-orchestrator": {
      "type": "orchestration",
      "enforcement": "suggest",
      "priority": "critical",
      "model": "opus",
      "description": "Master orchestrator for complete feature workflows from analysis to verification",
      "promptTriggers": {
        "keywords": [
          "workflow",
          "full feature",
          "complete implementation",
          "end-to-end feature",
          "feature lifecycle",
          "analysis to implementation",
          "feature workflow",
          "orchestrate feature",
          "phase management",
          "fonctionnalite complete",
          "implementation complete",
          "fonctionnalite bout en bout",
          "cycle de vie fonctionnalite",
          "analyse a implementation",
          "workflow fonctionnalite",
          "orchestrer fonctionnalite",
          "gestion des phases"
        ],
        "intentPatterns": [
          "workflow.*?(orchestrat|manage|start|launch|run)",
          "workflow.*?(orchestr|g[\u00e9e]rer|d[\u00e9e]marrer|lancer)",
          "(full|complete|end-to-end).*?(feature|implementation|workflow)",
          "(compl[e\u00e8]te?|bout en bout|enti[e\u00e8]re?).*?(fonctionnalit[\u00e9e]|impl[\u00e9e]mentation|workflow)",
          "feature.*?(lifecycle|workflow|orchestrat)",
          "fonctionnalit[\u00e9e].*?(cycle de vie|workflow|orchestr)",
          "(analysis|design|blueprint|implementation|verification).*?phase",
          "(analyse|conception|blueprint|impl[\u00e9e]mentation|v[\u00e9e]rification).*?phase",
          "orchestrat.*?(feature|workflow|implementation)",
          "orchestr.*?(fonctionnalit[\u00e9e]|workflow|impl[\u00e9e]mentation)",
          "phase.*?(management|transition|execution)",
          "phase.*?(gestion|transition|ex[\u00e9e]cution)"
        ]
      },
      "delegationCriteria": {
        "when": [
          "Complex feature requiring all phases (analysis -> design -> blueprint -> implementation -> review)",
          "Need coordinated multi-phase workflow",
          "Feature with human validation checkpoints",
          "Need state tracking across sessions"
        ],
        "parallelWith": []
      }
    }
  },
  "parallelExecutionGuide": {
    "description": "Guide for when to launch agents in parallel vs sequentially",
    "patterns": [
      {
        "name": "Research Phase",
        "parallel": [
          "analyst",
          "architect"
        ],
        "description": "Explore codebase and design architecture simultaneously"
      },
      {
        "name": "Implementation Phase",
        "parallel": [
          "task-orchestrator",
          "test-dev"
        ],
        "description": "Implement features and generate tests in parallel"
      },
      {
        "name": "Multi-Search",
        "parallel": [
          "analyst",
          "analyst",
          "analyst"
        ],
        "description": "Multiple independent codebase searches (different keywords/areas)"
      }
    ],
    "sequential": [
      {
        "order": [
          "analyst",
          "architect",
          "task-orchestrator",
          "code-review-dev"
        ],
        "description": "Full feature workflow: Research -> Design -> Implement -> Review"
      }
    ]
  }
}
