{
  "version": "1.0",
  "description": "Skill activation triggers for Claude Code in SkillForge backend. Controls when skills automatically suggest or block actions. Supports English and French triggers.",
  "skills": {
    "db-entity-change": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "high",
      "description": "Create new database entities or modify existing ones with automatic migration generation",
      "promptTriggers": {
        "keywords": [
          "create entity",
          "add column",
          "modify entity",
          "new table",
          "database schema change",
          "add property to entity",
          "alter table",
          "create migration",
          "add field",
          "new entity",
          "sqlalchemy entity",
          "orm entity",
          "database model",
          "mapped column",
          "table schema",
          "creer entite",
          "ajouter colonne",
          "modifier entite",
          "nouvelle table",
          "changement schema",
          "ajouter propriete",
          "ajouter champ",
          "nouvelle entite",
          "creer migration",
          "modele base de donnees",
          "schema table"
        ],
        "intentPatterns": [
          "(create|add|modify|alter).*?(entity|table|column|field|property)",
          "(cr[\u00e9e]e|ajoute|modifie|alt[e\u00e8]re).*?(entit[\u00e9e]|table|colonne|champ|propri[\u00e9e]t[\u00e9e])",
          "entity.*?(create|add|modify|new)",
          "entit[\u00e9e].*?(cr[\u00e9e]er|ajouter|modifier|nouvelle?)",
          "(database|db|schema).*?(change|migration|update|alter)",
          "(base de donn[\u00e9e]es|bdd|sch[\u00e9e]ma).*?(changement|migration|mise [\u00e0a] jour|modifier)",
          "sqlalchemy.*?(entity|model|table|entit[\u00e9e]|mod[e\u00e8]le)",
          "migration.*?(create|generate|add|script|cr[\u00e9e]er|g[\u00e9e]n[\u00e9e]rer|ajouter)"
        ]
      }
    },
